{
  "kind": "collectionType",
  "collectionName": "webinars",
  "info": {
    "singularName": "webinar",
    "pluralName": "webinars",
    "displayName": "Вебінари",
    "description": "Керування вебінарами, додавання заголовка, підзаголовка, міні-субтитрів, дати та зображення"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": { "type": "string", "required": true, "displayName": "Назва вебінару" },
    "youtube_url": { "type": "string", "required": false, "displayName": "URL відео на YouTube" },
    "subtitle": {
      "type": "text",
      "required": true,
      "displayName": "Підзаголовок"
    },
    "image": { "type": "media", "multiple": false, "required": false, "displayName": "Зображення" },
    "date": { "type": "date", "required": true, "displayName": "Дата вебінару" },
    "time": { "type": "time", "required": true, "displayName": "Час проведення" },
    "usefuls": {
      "type": "component",
      "repeatable": true,
      "component": "content.useful",
      "max": 20
    },
    "learnings": {
      "type": "component",
      "repeatable": true,
      "component": "content.learning",
      "max": 20
    },
    "events": {
      "type": "component",
      "repeatable": true,
      "component": "content.event",
      "max": 20
    },
    "benefits": {
      "type": "component",
      "repeatable": true,
      "component": "content.benefit",
      "max": 20
    }
  }
}
