{
  "kind": "collectionType",
  "collectionName": "webinars",
  "info": {
    "singularName": "webinar",
    "pluralName": "webinars",
    "displayName": "Вебінари",
    "description": "Керування вебінарами, додавання заголовка, підзаголовка, міні-субтитрів, дати та зображення"
